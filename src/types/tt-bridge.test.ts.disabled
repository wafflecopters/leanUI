/**
 * Tests for TT Bridge (UI → TT conversion)
 */

import { describe, it, expect } from 'vitest';
import { expressionNodeToTTerm, createEqualityProofTerm } from './tt-bridge';
import { parseExpressionToAST } from './enhanced-focus';
import { prettyPrint } from './tt-core';

describe('expressionNodeToTTerm', () => {
  it('converts simple variable', () => {
    const expr = parseExpressionToAST('a');
    const ttTerm = expressionNodeToTTerm(expr);
    const pretty = prettyPrint(ttTerm);
    expect(pretty).toBe('a');
  });

  it('converts literal number', () => {
    const expr = parseExpressionToAST('42');
    const ttTerm = expressionNodeToTTerm(expr);
    const pretty = prettyPrint(ttTerm);
    expect(pretty).toBe('42');
  });

  it('converts binary operation a + b', () => {
    const expr = parseExpressionToAST('a + b');
    const ttTerm = expressionNodeToTTerm(expr);
    const pretty = prettyPrint(ttTerm);
    // Should be: ((+ a) b)
    expect(pretty).toContain('+');
    expect(pretty).toContain('a');
    expect(pretty).toContain('b');
  });

  it('converts equality a = b', () => {
    const expr = parseExpressionToAST('a = b');
    const ttTerm = expressionNodeToTTerm(expr);
    const pretty = prettyPrint(ttTerm);
    // Should contain eq, a, and b
    expect(pretty).toContain('eq');
    expect(pretty).toContain('a');
    expect(pretty).toContain('b');
  });

  it('converts complex expression a + a = 2 * a', () => {
    const expr = parseExpressionToAST('a + a = 2 * a');
    const ttTerm = expressionNodeToTTerm(expr);
    const pretty = prettyPrint(ttTerm);

    // Should contain eq, +, *, a, and 2
    expect(pretty).toContain('eq');
    expect(pretty).toContain('+');
    expect(pretty).toContain('*');
    expect(pretty).toContain('a');
    expect(pretty).toContain('2');
  });

  it('handles application nodes (space-separated)', () => {
    // This tests if the parser creates application nodes
    // and if we handle them correctly
    const expr = parseExpressionToAST('f x y');
    expect(expr.type).toBe('application');

    const ttTerm = expressionNodeToTTerm(expr);
    const pretty = prettyPrint(ttTerm);

    // Should be nested applications: ((f x) y)
    expect(pretty).toContain('f');
    expect(pretty).toContain('x');
    expect(pretty).toContain('y');
  });

  it('converts unary negation', () => {
    const expr = parseExpressionToAST('-a');
    const ttTerm = expressionNodeToTTerm(expr);
    const pretty = prettyPrint(ttTerm);
    expect(pretty).toContain('-');
    expect(pretty).toContain('a');
  });
});

describe('createEqualityProofTerm', () => {
  it('creates proof term for simple equality', () => {
    const expr = parseExpressionToAST('a = b');

    // Create a mock LetElement
    const letBinding = {
      id: 'test-id',
      name: 'thm',
      type: 'let' as const,
      content: expr,
      value: expr,
      timestamp: Date.now()
    };

    const goal = expr.children[1]; // RHS: b
    const proofTerm = createEqualityProofTerm(letBinding, goal);

    expect(proofTerm.letId).toBe('test-id');
    expect(proofTerm.letName).toBe('thm');
    expect(proofTerm.holes).toHaveLength(1);
    expect(proofTerm.completed).toBe(false);

    // Check that propType is an equality
    const typeStr = prettyPrint(proofTerm.propType);
    expect(typeStr).toContain('eq');
  });

  it('creates proof term for a+a = 2*a', () => {
    const expr = parseExpressionToAST('a + a = 2 * a');

    const letBinding = {
      id: 'test-thm',
      name: 'thm',
      type: 'let' as const,
      content: expr,
      value: expr,
      timestamp: Date.now()
    };

    const goal = expr.children[1]; // RHS: 2*a
    const proofTerm = createEqualityProofTerm(letBinding, goal);

    expect(proofTerm.letName).toBe('thm');
    expect(proofTerm.holes).toHaveLength(1);
    expect(proofTerm.holes[0]).toBe('proof_test-thm');

    // Verify the type contains the equality
    const typeStr = prettyPrint(proofTerm.propType);
    expect(typeStr).toContain('eq');

    // Verify the proof term is a hole
    const termStr = prettyPrint(proofTerm.proofTerm);
    expect(termStr).toContain('?proof_test-thm');
  });
});
