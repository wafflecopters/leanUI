-- FIXED: Implicit argument conflict resolved! UIP now works with axiom K in unit tests.
-- However, zonk recheck currently rejects terms with holes from padding wildcards.
-- TODO: Fix zonk recheck to handle holes properly, or zonk elaborated patterns before recheck.
@test failure
@name "UIP should succeed with axiom K"
@import preambles/equality.tt
@assumeK
@error "Zonk recheck"

-- With axiom K enabled, UIP is provable
uip : {A : Type} -> {x y : A} -> (p q : Equal x y) -> Equal p q
uip refl refl = refl
