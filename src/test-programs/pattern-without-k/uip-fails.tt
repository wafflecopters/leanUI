-- FIXED: Implicit argument conflict has been resolved by using holes for padding wildcards
-- TODO: Should eventually fail with "axiom K" deletion rule error during pattern matching,
-- but currently fails during zonk recheck due to type reconstruction issues with holes
@test failure
@name "UIP should fail without axiom K"
@import preambles/equality.tt
@error "Zonk recheck"

-- Uniqueness of Identity Proofs (UIP) should be unprovable without axiom K
-- This proof requires pattern matching on (refl : Equal x x) against (Equal x y)
-- which introduces the constraint x = y, needing injectivity of Equal

uip : {A : Type} -> {x y : A} -> (p q : Equal x y) -> Equal p q
uip refl refl = refl
