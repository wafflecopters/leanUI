@test failure
@name "UIP should fail without axiom K"
@import preambles/equality.tt
@assumeK=false
@error "axiom K"

-- Uniqueness of Identity Proofs (UIP) should be unprovable without axiom K
-- The second pattern match on refl requires the deletion rule because it
-- forces equality of proof objects, which needs K

uip : {A : Type} -> {x y : A} -> (p q : Equal x y) -> Equal p q
uip refl refl = refl
