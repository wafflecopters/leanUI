@test success
@name "multi-tactic: comprehensive syntax test (multiline, semicolon, nested)"
@import preambles/nat.tt

inductive Equal : {A : Type} -> A -> A -> Type where
  refl : {A : Type} -> {a : A} -> Equal a a

congSucc : {n m : Nat} -> Equal n m -> Equal (Succ n) (Succ m)
congSucc refl = refl

sym : {A : Type} -> {x y : A} -> Equal x y -> Equal y x
sym refl = refl

trans : {A : Type} -> {x y z : A} -> Equal x y -> Equal y z -> Equal x z
trans refl refl = refl

plus : Nat -> Nat -> Nat
plus Zero m = m
plus (Succ n) m = Succ (plus n m)

-- Test all multi-tactic syntaxes
plusZeroRight : (n : Nat) -> Equal (plus n Zero) n := by
  intro n
  induction n with
  | Zero => exact refl
  | Succ n' IH => apply congSucc; exact IH

plusSymmetry : (n : Nat) -> Equal n (plus n Zero) := by
  intro n
  induction n with
  | Zero => exact refl
  | Succ n' IH =>
    apply sym
    apply congSucc
    apply sym
    exact IH
