@test success
@name "rewrite: replaces all occurrences"
@import preambles/nat.tt

inductive Equal : {A : Type} -> A -> A -> Type where
  refl : {A : Type} -> {a : A} -> Equal a a

sym : {A : Type} -> {x y : A} -> Equal x y -> Equal y x
sym refl = refl

replace : {A : Type} -> {x y : A} -> (P : A -> Type) -> Equal x y -> P x -> P y
replace P refl px = px

-- Both occurrences of n in the goal should be rewritten to m
test : {n m : Nat} -> Equal n m -> Equal (Succ n) (Succ n) := by
  intros n m h
  rewrite h
  exact refl
