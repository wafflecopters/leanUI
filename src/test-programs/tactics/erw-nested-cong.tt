@test success
@name "erw: deeply nested wrapper aliases"

inductive Equal : {A : Type} -> A -> A -> Type where
  refl : {A : Type} -> {a : A} -> Equal a a

trans : {A : Type} -> {x y z : A} -> Equal x y -> Equal y z -> Equal x z
trans refl refl = refl

inductive Nat : Type where
  Zero : Nat
  Succ : Nat -> Nat

-- Three wrapper layers
f : Nat -> Nat
f x = x

g : Nat -> Nat
g x = f x

h : Nat -> Nat
h x = g x

-- h(n) = g(n) = f(n) = n — each expands through WHNF
-- erw should handle nested wrapper equality
step1 : (n : Nat) -> Equal (h n) (g n)
step1 n = refl

step2 : (n : Nat) -> Equal (g n) (f n)
step2 n = refl

step3 : (n : Nat) -> Equal (f n) n
step3 n = refl

test : (n : Nat) -> Equal (h n) n := by
  intros n
  erw (step1 n), (step2 n), (step3 n)
