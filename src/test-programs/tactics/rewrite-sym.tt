@test success
@name "rewrite: rewrite with sym for reverse direction"
@import preambles/nat.tt

inductive Equal : {A : Type} -> A -> A -> Type where
  refl : {A : Type} -> {a : A} -> Equal a a

sym : {A : Type} -> {x y : A} -> Equal x y -> Equal y x
sym refl = refl

replace : {A : Type} -> {x y : A} -> (P : A -> Type) -> Equal x y -> P x -> P y
replace P refl px = px

-- rewrite (sym h) where h : Equal n m rewrites m to n
test : {n m : Nat} -> Equal n m -> Equal (Succ m) (Succ n) := by
  intros n m h
  rewrite (sym h)
  exact refl
