@test success
@name "erw: double record wrapper (real-analysis pattern)"

-- Simulates the real-analysis pattern: Real wraps MyField
-- negLeft uses wrappers (radd, rneg, rzero) that go through BOTH record layers

inductive Equal : {A : Type} -> A -> A -> Type where
  refl : {A : Type} -> {a : A} -> Equal a a

trans : {A : Type} -> {x y z : A} -> Equal x y -> Equal y z -> Equal x z
trans refl refl = refl

record MyField (A : Type) where
  constructor MkMyField
  add : A -> A -> A
  zero : A
  neg : A -> A
  addComm : (x y : A) -> Equal (add x y) (add y x)
  negRight : (a : A) -> Equal (add a (neg a)) zero

record Env where
  constructor MkEnv
  Carrier : Type
  inst : MyField Carrier

-- Wrappers
radd : {R : Env} -> Env.Carrier R -> Env.Carrier R -> Env.Carrier R
radd {R} x y = MyField.add (Env.inst R) x y

rneg : {R : Env} -> Env.Carrier R -> Env.Carrier R
rneg {R} x = MyField.neg (Env.inst R) x

rzero : (R : Env) -> Env.Carrier R
rzero R = MyField.zero (Env.inst R)

-- negLeft: radd (rneg a) a = rzero R
negLeft : (R : Env) -> (a : Env.Carrier R) -> Equal (radd (rneg a) a) (rzero R) := by
  intros R a
  erw (MyField.addComm (Env.inst R) (rneg a) a), (MyField.negRight (Env.inst R) a)
