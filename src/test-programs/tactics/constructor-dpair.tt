@test success
@name "constructor: DPair dependent pair"
@import preambles/nat.tt
@import preambles/dpair.tt
@import preambles/equality.tt

-- constructor on DPair creates subgoals for witness and proof
-- DPair Nat (\n => Equal n Zero) — exists n, n = Zero
existsZero : DPair Nat (\n => Equal n Zero) := by
  intros
  constructor
  exact Zero
  exact refl
