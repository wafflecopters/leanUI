-- Test that List pattern matching works without explicit {A}
-- FIXED: Positional args now allowed for types with only implicit params
-- @test success
-- @name "List pattern matching without explicit {A} works"
-- @import preambles/nat.tt

inductive List : {A : Type} -> Type where
  Nil : {A : Type} -> List {A}
  Cons : {A : Type} -> A -> List {A} -> List {A}

-- Pattern match on List without explicit {A}
head : {A : Type} -> A -> List A -> A
head default Nil = default
head default (Cons x xs) = x
