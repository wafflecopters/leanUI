-- Test that eqEqual (UIP-like structure) fails without explicit {A}
-- Same bug as UIP: implicit argument conflict
@test failure
@name "eqEqual (UIP-like) without explicit {A} (bug exists)"
@import preambles/nat.tt
@error "Implicit argument conflict"

inductive Equal : {A: Type} -> A -> A -> Type where
  refl : (A : Type) -> (a : A) -> Equal a a

-- Takes TWO equality proofs like UIP, returns proof they're equal
-- The return type explicitly says: the A parameter is an equality type
eqEqual : {A : Type} -> {x y : A} -> (p q : Equal x y) -> Equal {A:=Equal {A} x y} p q
eqEqual (refl _ _) (refl _ _) = refl _ _
