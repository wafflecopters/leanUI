-- Test the original UIP bug you reported
-- NOTE: This still fails while eqEqual passes - might be related to name resolution or ordering?
@test failure
@name "UIP without explicit {A} (bug still exists)"
@import preambles/nat.tt
@error "Implicit argument conflict"

inductive Equal : {A: Type} -> A -> A -> Type where
  refl : (A : Type) -> (a : A) -> Equal a a

-- This is the version that you said fails (without {A} in first pattern):
uip : {A : Type} -> {x y : A} -> (p q : Equal x y) -> Equal {A:=Equal {A} x y} p q
uip (refl _ _) (refl _ _) = refl _ _
