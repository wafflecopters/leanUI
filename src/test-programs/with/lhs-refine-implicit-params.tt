-- LHS refinement on function with implicit parameters
-- The refined patterns only cover EXPLICIT arguments
@test success
@name "LHS refinement: function with implicit params"
@import preambles/nat.tt
@import preambles/bool.tt
@import preambles/list.tt

isEmpty : {A : Type} -> List A -> Bool
isEmpty xs with xs
  isEmpty _ | Nil => True
  isEmpty _ | Cons _ _ => False
