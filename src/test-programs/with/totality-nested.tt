-- @test success
-- @name "nested with totality: inner with checked independently"
-- @import preambles/nat.tt
-- @import preambles/bool.tt

classify : Nat -> Nat -> Bool
classify m n with m
  | Zero with n
    | Zero => True
    | Succ _ => False
  | Succ _ with n
    | Zero => False
    | Succ _ => True
